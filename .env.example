# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1
SWAGGER_PATH=docs

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/classivo

# Redis / Queues
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Multi-tenancy
DEFAULT_TENANT_MODE=multi
TENANT_HEADER_KEY=x-school-id

# S3-compatible storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=classivo-dev
S3_ACCESS_KEY_ID=replace_with_s3_access_key
S3_SECRET_ACCESS_KEY=replace_with_s3_secret_key
S3_FORCE_PATH_STYLE=true

# Security
SALT_ROUND=10
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Logging
LOG_LEVEL=debug

# Seed defaults
DEFAULT_ADMIN_EMAIL=admin@classivo.local
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_FIRST_NAME=System
DEFAULT_ADMIN_LAST_NAME=Admin
